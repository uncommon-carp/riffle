# Copy to .env and fill in. Never commit real secrets.

# BFF
PORT=3001
AGENT_URL=http://localhost:8000
DEV_JWT=dev-token
WEB_ORIGIN=http://localhost:3000

# Agent — remote model API keys (omit to use local Ollama models)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Agent — Sentinel scanner
# "stub" (default) returns canned findings and needs no scanner or live target.
# "real" runs Sentinel against the target URL.
SENTINEL_MODE=stub
# How to invoke the Sentinel CLI. Leave unset to auto-detect an adjacent local
# build (../sentinel/dist/cli/index.js) and otherwise use the published package.
# SENTINEL_BIN=npx --yes @uncommon-carp/sentinel

# Web (must be NEXT_PUBLIC_ to reach the browser bundle)
NEXT_PUBLIC_BFF_URL=http://localhost:3001
NEXT_PUBLIC_DEV_JWT=dev-token
